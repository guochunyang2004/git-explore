{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GitExplore",
  "version": "0.1.0",
  "identifier": "com.gitexplore.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "GitExplore",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": false,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "SimpChinese"],
        "displayLanguageSelector": true,
        "compression": "lzma",
        "startMenuFolder": "GitExplore"
      }
    },
    "copyright": "GitExplore Contributors",
    "shortDescription": "Desktop Git repository manager",
    "longDescription": "Browse, manage and batch-operate multiple Git repositories from a single window."
  },
  "plugins": {}
}

